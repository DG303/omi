# Minimal env for the self-hosted stack (docker-compose.selfhost.yml).
# Copy to backend/.env on the host and fill in. QDRANT_*, REDIS_DB_*, and
# HOSTED_PUSHER_API_URL are injected by compose — do not set them here.

# --- Firebase / GCP (own project) ---
# Entire service-account JSON on ONE line (used by main.py for Firestore/GCS)
SERVICE_ACCOUNT_JSON=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# GCS buckets (create in your project; speech-profiles needed for speaker ID)
BUCKET_SPEECH_PROFILES=
BUCKET_BACKUPS=
BUCKET_MEMORIES_RECORDINGS=
BUCKET_CHAT_FILES=

# --- STT ---
DEEPGRAM_API_KEY=

# --- LLM + embeddings ---
OPENAI_API_KEY=

# --- Core ---
# Generate your own: python3 -c "import secrets; print('omi_' + secrets.token_urlsafe(48))"
ENCRYPTION_SECRET=
# Local dev auth bypass token prefix (any random string)
ADMIN_KEY=

# Tailnet URL of this backend (used in links the backend generates)
BASE_API_URL=http://your-host:8080/
API_BASE_URL=http://your-host:8080/
